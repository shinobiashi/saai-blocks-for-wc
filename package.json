{
	"name": "saai-blocks-for-wc",
	"version": "0.1.0",
	"author": "Shohei Tanaka",
	"license": "GPL-3.0+",
	"scripts": {
		"build": "wp-scripts build --blocks-manifest",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"makepot": "npx wp-env run cli wp i18n make-pot /var/www/html/wp-content/plugins/saai-blocks-for-wc /var/www/html/wp-content/plugins/saai-blocks-for-wc/languages/saai-blocks-for-wc.pot --domain=saai-blocks-for-wc --exclude=vendor,node_modules,build,tests",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start --blocks-manifest",
		"postinstall": "composer install"
	},
	"dependencies": {
		"@woocommerce/components": "*",
		"@wordpress/block-editor": "*",
		"@wordpress/blocks": "*",
		"@wordpress/components": "*",
		"@wordpress/element": "*",
		"@wordpress/hooks": "*",
		"@wordpress/i18n": "*"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@woocommerce/dependency-extraction-webpack-plugin": "latest",
		"@woocommerce/eslint-plugin": "latest",
		"@wordpress/e2e-test-utils-playwright": "^1.47.0",
		"@wordpress/prettier-config": "latest",
		"@wordpress/scripts": "^32.2.0"
	},
	"overrides": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"zod": "^4.0.0"
	}
}
