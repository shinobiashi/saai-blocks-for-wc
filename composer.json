{
	"name": "saaitanaka/saai-blocks-for-wc",
	"description": "WooCommerce-focused Gutenberg blocks for the frontend and admin.",
	"license": "GPL-3.0-or-later",
	"autoload": {
		"psr-4": {
			"SaaiBlocksForWc\\": "includes/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.0",
		"automattic/jetpack-autoloader": "^2",
		"phpstan/phpstan": "^2.0",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"php-stubs/woocommerce-stubs": "^9.0",
		"wp-coding-standards/wpcs": "^3.3",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"config": {
		"allow-plugins": {
			"automattic/jetpack-autoloader": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpstan": "php -d memory_limit=512M vendor/bin/phpstan analyse",
		"phpcs": "vendor/bin/phpcs --standard=WordPress --extensions=php --ignore=vendor,node_modules --warning-severity=0 saai-blocks-for-wc.php includes/"
	}
}
