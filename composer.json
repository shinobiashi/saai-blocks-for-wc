{
	"name": "saaitanaka/saai-blocks-for-wc",
	"description": "WooCommerce-focused Gutenberg blocks for the frontend and admin.",
	"license": "GPL-3.0-or-later",
	"autoload": {
		"psr-4": {
			"SaaiBlocksForWc\\": "includes/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.0",
		"automattic/jetpack-autoloader": "^2",
		"phpstan/phpstan": "^2.0",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"php-stubs/woocommerce-stubs": "^9.0"
	},
	"config": {
		"allow-plugins": {
			"automattic/jetpack-autoloader": true
		}
	},
	"scripts": {
		"phpstan": "php -d memory_limit=512M vendor/bin/phpstan analyse"
	}
}
